{
  "name": "solana-agent-wallet",
  "version": "1.0.0",
  "description": "Autonomous Solana Agents with Agentic Wallets",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts --agents=3 --interval=10",
    "dashboard": "ts-node src/server.ts",
    "spl-demo": "ts-node src/splDemo.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "clean": "rimraf dist"
  },
  "keywords": [
    "solana",
    "agent",
    "wallet",
    "blockchain",
    "autonomous"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.0",
    "blessed": "^0.1.81",
    "bs58": "^5.0.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/blessed": "^0.1.25",
    "@types/bs58": "^4.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "jest": "^29.7.0",
    "rimraf": "^5.0.9",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}