# Encryption password for AES-256-CBC key storage
# CHANGE THIS to a strong, random password before using in production.
ENCRYPTION_PASSWORD=change_me_to_a_strong_random_password_at_least_32_chars

# Solana Devnet RPC URL (default is fine for development)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to the encrypted keys file (relative to project root)
KEYS_FILE_PATH=keys.json

# Log file path (optional, logs to console if not set)
# LOG_FILE_PATH=agent-actions.log
